      <supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements>
        <enum id="BackgroundColor" key="Software\Policies\NetBannerNG" valueName="CustomBackgroundColor">
          <item displayName="$(string.unknown_10)"><value><string>#007A33</string></value></item>
          <item displayName="$(string.unknown_11)"><value><string>#0033A0</string></value></item>
