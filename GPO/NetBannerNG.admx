<?xml version="1.0" encoding="utf-8"?>
<policyDefinitions revision="1.0" schemaVersion="1.0" xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions">
  <!-- NetbannerNG (backwards-compatible with NetBanner 2.0.130) -->
  <policyNamespaces>
    <target prefix="netbannerng" namespace="DeltaZulu.Policies.NetBannerNG" />
  </policyNamespaces>
  <resources minRequiredRevision="1.0" />
  <supportedOn>
    <definitions>
      <definition name="SUPPORTED_NotSpecified" displayName="$(string.ADMXMigrator_NoSupportedOn)" />
      <definition name="SUPPORTED_Windows10_AndLater" displayName="$(string.SUPPORTED_Windows10_AndLater)" />
    </definitions>
  </supportedOn>
  <categories>
    <category name="NetBannerNG" displayName="$(string.unknown_0)" />
  </categories>
  <policies>
    <!-- Legacy NetBanner policy/value mappings are preserved as-is for backward compatibility. -->
    <!-- NetBannerNG extensions are explicitly labeled below and use additive values only. -->
    <policy name="Classification" class="Machine" displayName="$(string.unknown_1)" explainText="$(string.Classification_Help)" presentation="$(presentation.Classification)" key="Software\Policies\NetBannerNG" valueName="Classification">
      <parentCategory ref="NetBannerNG" />
      <supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements>
        <enum id="Classification" key="Software\Policies\NetBannerNG" valueName="Classification">
          <item displayName="$(string.unknown_3)"><value><decimal value="1" /></value></item>
          <item displayName="$(string.unknown_4)"><value><decimal value="2" /></value></item>
          <item displayName="$(string.unknown_5)"><value><decimal value="3" /></value></item>
          <item displayName="$(string.unknown_6)"><value><decimal value="4" /></value></item>
          <item displayName="$(string.ng_classification_5)"><value><decimal value="5" /></value></item>
          <item displayName="$(string.ng_classification_6)"><value><decimal value="6" /></value></item>
          <item displayName="$(string.ng_classification_7)"><value><decimal value="7" /></value></item>
          <item displayName="$(string.ng_classification_8)"><value><decimal value="8" /></value></item>
          <item displayName="$(string.ng_classification_9)"><value><decimal value="9" /></value></item>
        </enum>
      </elements>
    </policy>
    <policy name="CustomSettings" class="Machine" displayName="$(string.unknown_7)" explainText="$(string.unknown_8)" presentation="$(presentation.CustomSettings)" key="Software\Policies\NetBannerNG" valueName="CustomSettings">
      <parentCategory ref="NetBannerNG" />
      <supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements>
        <enum id="BackgroundColor" key="Software\Policies\NetBannerNG" valueName="CustomBackgroundColor">
          <item displayName="$(string.unknown_10)"><value><decimal value="1" /></value></item>
          <item displayName="$(string.unknown_11)"><value><decimal value="2" /></value></item>
          <item displayName="$(string.unknown_12)"><value><decimal value="3" /></value></item>
          <item displayName="$(string.unknown_13)"><value><decimal value="4" /></value></item>
          <item displayName="$(string.unknown_14)"><value><decimal value="5" /></value></item>
          <item displayName="$(string.unknown_15)"><value><decimal value="6" /></value></item>
          <item displayName="$(string.unknown_16)"><value><decimal value="7" /></value></item>
          <item displayName="$(string.unknown_17)"><value><decimal value="8" /></value></item>
          <item displayName="$(string.unknown_18)"><value><decimal value="9" /></value></item>
        </enum>
        <enum id="TextColor" key="Software\Policies\NetBannerNG" valueName="CustomForeColor">
          <item displayName="$(string.unknown_20)"><value><decimal value="1" /></value></item>
          <item displayName="$(string.unknown_21)"><value><decimal value="2" /></value></item>
          <item displayName="$(string.unknown_22)"><value><decimal value="3" /></value></item>
        </enum>
        <text id="DisplayText" key="Software\Policies\NetBannerNG" valueName="CustomDisplayText" />
      </elements>
    </policy>
    <policy name="InformationCondition" class="Machine" displayName="$(string.unknown_24)" explainText="$(string.InformationCondition_Help)" presentation="$(presentation.InformationCondition)" key="Software\Policies\NetBannerNG" valueName="InfoCon">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements><enum id="InformationCondition" key="Software\Policies\NetBannerNG" valueName="InfoCon">
          <item displayName="$(string.unknown_26)"><value><decimal value="1" /></value></item>
          <item displayName="$(string.unknown_27)"><value><decimal value="2" /></value></item>
          <item displayName="$(string.unknown_28)"><value><decimal value="3" /></value></item>
          <item displayName="$(string.unknown_29)"><value><decimal value="4" /></value></item>
          <item displayName="$(string.unknown_30)"><value><decimal value="5" /></value></item>
      </enum></elements>
    </policy>
    <policy name="ForceProtectionCondition" class="Machine" displayName="$(string.unknown_31)" explainText="$(string.ForceProtectionCondition_Help)" presentation="$(presentation.ForceProtectionCondition)" key="Software\Policies\NetBannerNG" valueName="FpCon">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements><enum id="ForceProtection" key="Software\Policies\NetBannerNG" valueName="FpCon">
          <item displayName="$(string.unknown_33)"><value><decimal value="1" /></value></item>
          <item displayName="$(string.unknown_34)"><value><decimal value="2" /></value></item>
          <item displayName="$(string.unknown_35)"><value><decimal value="3" /></value></item>
          <item displayName="$(string.unknown_36)"><value><decimal value="4" /></value></item>
      </enum></elements>
    </policy>
    <policy name="Caveats" class="Machine" displayName="$(string.unknown_37)" explainText="$(string.Caveats_Help)" presentation="$(presentation.Caveats)" key="Software\Policies\NetBannerNG" valueName="CaveatsEnabled">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <enabledValue><decimal value="1" /></enabledValue><disabledValue><decimal value="0" /></disabledValue>
      <elements><text id="SizeMessage" key="Software\Policies\NetBannerNG" valueName="Caveats" maxLength="40" /></elements>
    </policy>
    <policy name="FontSize" class="Machine" displayName="$(string.ng_fontsize_display)" explainText="$(string.ng_fontsize_help)" presentation="$(presentation.FontSize)" key="Software\Policies\NetBannerNG" valueName="FontSize">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements><decimal id="FontSizeValue" key="Software\Policies\NetBannerNG" valueName="FontSize" minValue="6" maxValue="48" /></elements>
    </policy>
    <policy name="BannerSize" class="Machine" displayName="$(string.ng_bannersize_display)" explainText="$(string.ng_bannersize_help)" presentation="$(presentation.BannerSize)" key="Software\Policies\NetBannerNG" valueName="BannerSize">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements><decimal id="BannerSizeValue" key="Software\Policies\NetBannerNG" valueName="BannerSize" minValue="10" maxValue="100" /></elements>
    </policy>
    <policy name="DisableBorders" class="Machine" displayName="$(string.ng_disableborders_display)" explainText="$(string.ng_disableborders_help)" key="Software\Policies\NetBannerNG" valueName="DisableBorders">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <enabledValue><decimal value="1" /></enabledValue><disabledValue><decimal value="0" /></disabledValue>
    </policy>
    <policy name="ClassificationProfile" class="Machine" displayName="$(string.ng_classificationprofile_display)" explainText="$(string.ng_classificationprofile_help)" presentation="$(presentation.ClassificationProfile)" key="Software\Policies\NetBannerNG" valueName="ClassificationProfile">
      <parentCategory ref="NetBannerNG" />
      <supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <elements>
        <enum id="ClassificationProfile" key="Software\Policies\NetBannerNG" valueName="ClassificationProfile">
          <item displayName="$(string.ng_classificationprofile_nato)"><value><string>NATO</string></value></item>
          <item displayName="$(string.ng_classificationprofile_us)"><value><string>US</string></value></item>
          <item displayName="$(string.ng_classificationprofile_uk)"><value><string>UK</string></value></item>
          <item displayName="$(string.ng_classificationprofile_ca)"><value><string>CA</string></value></item>
          <item displayName="$(string.ng_classificationprofile_au)"><value><string>AU</string></value></item>
          <item displayName="$(string.ng_classificationprofile_de)"><value><string>DE</string></value></item>
          <item displayName="$(string.ng_classificationprofile_dk)"><value><string>DK</string></value></item>
          <item displayName="$(string.ng_classificationprofile_euci)"><value><string>EUCI</string></value></item>
          <item displayName="$(string.ng_classificationprofile_ep)"><value><string>EP</string></value></item>
          <item displayName="$(string.ng_classificationprofile_ee)"><value><string>EE</string></value></item>
          <item displayName="$(string.ng_classificationprofile_fr)"><value><string>FR</string></value></item>
          <item displayName="$(string.ng_classificationprofile_it)"><value><string>IT</string></value></item>
          <item displayName="$(string.ng_classificationprofile_pl)"><value><string>PL</string></value></item>
          <item displayName="$(string.ng_classificationprofile_fi)"><value><string>FI</string></value></item>
          <item displayName="$(string.ng_classificationprofile_se)"><value><string>SE</string></value></item>
          <item displayName="$(string.ng_classificationprofile_tr)"><value><string>TR</string></value></item>
          <item displayName="$(string.ng_classificationprofile_ua)"><value><string>UA</string></value></item>
          <item displayName="$(string.ng_classificationprofile_esa)"><value><string>ESA</string></value></item>
          <item displayName="$(string.ng_classificationprofile_oecd)"><value><string>OECD</string></value></item>
          <item displayName="$(string.ng_classificationprofile_euratom)"><value><string>EURATOM</string></value></item>
          <item displayName="$(string.ng_classificationprofile_wassenaar)"><value><string>WASSENAAR</string></value></item>
          <item displayName="$(string.ng_classificationprofile_osce)"><value><string>OSCE</string></value></item>
          <item displayName="$(string.ng_classificationprofile_opcw)"><value><string>OPCW</string></value></item>
          <item displayName="$(string.ng_classificationprofile_coe)"><value><string>COE</string></value></item>
          <item displayName="$(string.ng_classificationprofile_wto)"><value><string>WTO</string></value></item>
          <item displayName="$(string.ng_classificationprofile_icc)"><value><string>ICC</string></value></item>
          <item displayName="$(string.ng_classificationprofile_nsg)"><value><string>NSG</string></value></item>
          <item displayName="$(string.ng_classificationprofile_icty)"><value><string>ICTY</string></value></item>
          <item displayName="$(string.ng_classificationprofile_ag)"><value><string>AG</string></value></item>
          <item displayName="$(string.ng_classificationprofile_cceb)"><value><string>CCEB</string></value></item>
          <item displayName="$(string.ng_classificationprofile_un)"><value><string>UN</string></value></item>
          <item displayName="$(string.ng_classificationprofile_fvey)"><value><string>FVEY</string></value></item>
        </enum>
      </elements>
    </policy>
    <policy name="ShowHostInformation" class="Machine" displayName="$(string.ng_showhostinfo_display)" explainText="$(string.ng_showhostinfo_help)" key="Software\Policies\NetBannerNG" valueName="ShowHostInformation">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <enabledValue><decimal value="1" /></enabledValue><disabledValue><decimal value="0" /></disabledValue>
    </policy>
    <policy name="EnableBottomBanner" class="Machine" displayName="$(string.ng_enablebottombanner_display)" explainText="$(string.ng_enablebottombanner_help)" key="Software\Policies\NetBannerNG" valueName="EnableBottomBanner">
      <parentCategory ref="NetBannerNG" /><supportedOn ref="SUPPORTED_Windows10_AndLater" />
      <enabledValue><decimal value="1" /></enabledValue><disabledValue><decimal value="0" /></disabledValue>
    </policy>
  </policies>
</policyDefinitions>
