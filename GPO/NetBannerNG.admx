          <item displayName="$(string.unknown_34)"><value><decimal value="2" /></value></item>
          <item displayName="$(string.unknown_35)"><value><decimal value="3" /></value></item>
          <item displayName="$(string.unknown_36)"><value><decimal value="4" /></value></item>
      </enum></elements>
