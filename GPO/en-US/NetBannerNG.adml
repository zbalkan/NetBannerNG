      </presentation>
      <presentation id="Caveats">
        <textBox refId="SizeMessage"><label>40 Characters Max</label></textBox>
      </presentation>
      <presentation id="BannerSize">
        <decimalTextBox refId="BannerSizeValue" defaultValue="28" spin="true">Banner size (10-100)</decimalTextBox>
      </presentation>
      <presentation id="ClassificationProfile">
        <dropdownList refId="ClassificationProfile" noSort="true" defaultItem="0">Classification Profile</dropdownList>
      </presentation>
