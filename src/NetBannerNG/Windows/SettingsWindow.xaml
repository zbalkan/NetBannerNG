<Window
    x:Class="NetBannerNG.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:cntrl="clr-namespace:NumericUpDownLib;assembly=NumericUpDownLib"
    Title="NetBannerNG - Settings"
    Width="450"
    Height="420"
    FontSize="14"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <TabControl>
            <TabItem Header="Settings">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  COUNTER  -->
                    <Label
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Banner Border Size" />
                    <cntrl:DecimalUpDown
                        x:Name="decBannerBorderSize"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Grid.ColumnSpan="4"
                        Margin="10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        DisplayLength="12"
                        IsDisplayLengthFixed="True"
                        IsMouseDragEnabled="false"
                        IsReadOnly="False"
                        LargeStepSize="5"
                        MaxValue="100"
                        MinValue="5"
                        StepSize="1"
                        ToolTip="Banner size will dynamically change when the font size requires more space."
                        ValueChanged="decBannerBorderSize_ValueChanged" />
                    <Label
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="8"
                        Grid.ColumnSpan="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Content="pixels" />

                    <!--  Color picker  -->
                    <Label
                        Grid.Row="2"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Banner Color" />
                    <TextBox
                        x:Name="tbBannerColor"
                        Grid.Row="2"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Grid.ColumnSpan="4"
                        Margin="10"
                        MouseDoubleClick="tbBannerColor_MouseDoubleClick"
                        TextAlignment="Right"
                        ToolTip="Double-click to pick a color." />

                    <!--  Combobox  -->
                    <Label
                        Grid.Row="4"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Font Size" />
                    <ComboBox
                        x:Name="cboFontSize"
                        Grid.Row="4"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Grid.ColumnSpan="4"
                        Margin="10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        SelectionChanged="cboFontSize_SelectionChanged"
                        Text="12"
                        ToolTip="Banner size will dynamically change when the font size requires more space." />
                    <Label
                        Grid.Row="4"
                        Grid.RowSpan="2"
                        Grid.Column="8"
                        Grid.ColumnSpan="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Content="pts" />

                    <!--  Color picker  -->
                    <Label
                        Grid.Row="6"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Font Color" />
                    <TextBox
                        x:Name="tbFontColor"
                        Grid.Row="6"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Grid.ColumnSpan="4"
                        Margin="10"
                        MouseDoubleClick="tbFontColor_MouseDoubleClick"
                        TextAlignment="Right"
                        ToolTip="Double-click to pick a color." />

                    <!--  COUNTER  -->
                    <Label
                        Grid.Row="8"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Heartbeat" />
                    <cntrl:DecimalUpDown
                        x:Name="decHeartbeat"
                        Grid.Row="8"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Grid.ColumnSpan="4"
                        Margin="10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        DisplayLength="12"
                        IsDisplayLengthFixed="True"
                        IsMouseDragEnabled="false"
                        IsReadOnly="False"
                        LargeStepSize="100"
                        MaxValue="3600"
                        MinValue="10"
                        StepSize="1"
                        ToolTip="The lower the value, the higher load of network traffic and higher latency."
                        ValueChanged="decHeartbeat_ValueChanged" />
                    <Label
                        Grid.Row="8"
                        Grid.RowSpan="2"
                        Grid.Column="8"
                        Grid.ColumnSpan="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Content="seconds" />

                    <CheckBox
                        x:Name="cbDisableBorders"
                        Grid.Row="10"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Margin="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Checked="cbDisableBorders_Checked"
                        Unchecked="cbDisableBorders_Unchecked" />
                    <Label
                        Grid.Row="10"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Grid.ColumnSpan="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Content="Disable borders" />

                    <Button
                        x:Name="btExport"
                        Grid.Row="12"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        Click="btExport_Click"
                        Content="Export" />

                    <Button
                        x:Name="btSave"
                        Grid.Row="12"
                        Grid.RowSpan="2"
                        Grid.Column="7"
                        Grid.ColumnSpan="4"
                        Margin="5"
                        Click="btSave_Click"
                        Content="Save" />
                </Grid>
            </TabItem>
            <TabItem Header="About">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="2"
                        Grid.ColumnSpan="8"
                        Margin="5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Content="NetBannerNG" />
                    <Label
                        x:Name="lbVersion"
                        Grid.Row="1"
                        Grid.RowSpan="2"
                        Grid.Column="4"
                        Grid.ColumnSpan="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Content="Application Version" />

                    <Image
                        Grid.Row="8"
                        Grid.RowSpan="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="../Assets/info.png" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>