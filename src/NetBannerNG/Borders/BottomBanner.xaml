<borders:BorderBase
    x:Class="NetBannerNG.Borders.BottomBanner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:borders="clr-namespace:NetBannerNG.Borders"
    Title="BottomBanner"
    Closing="BorderBase_Closing"
    ResizeMode="NoResize"
    ScrollViewer.CanContentScroll="False"
    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
    ScrollViewer.VerticalScrollBarVisibility="Hidden"
    ShowInTaskbar="False"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStyle="None">

    <Border
        Background="{Binding CustomBackgroundColor}"
        Padding="10,0,10,0"
        ClipToBounds="True"
        SnapsToDevicePixels="True">

        <Grid
            x:Name="RootGrid"
            ClipToBounds="True"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Left column -->
            <TextBlock
                x:Name="TbHostInformation"
                Grid.Row="0"
                Grid.Column="0"
                Margin="4,1,4,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Arial, Segoe UI, Tahoma"
                FontWeight="Bold"
                Foreground="{Binding CustomForeColor}"
                LineHeight="11"
                LineStackingStrategy="BlockLineHeight"
                SnapsToDevicePixels="True"
                Text="{Binding HostInformation}"
                TextTrimming="CharacterEllipsis" />

            <TextBlock
                x:Name="TbCondition"
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,4,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontFamily="Arial"
                FontSize="9"
                FontWeight="Bold"
                Foreground="{Binding CustomForeColor}"
                LineHeight="11"
                LineStackingStrategy="BlockLineHeight"
                SnapsToDevicePixels="True"
                Text="{Binding ConditionMetadata}"
                TextTrimming="CharacterEllipsis" />

            <!-- Center column -->
            <TextBlock
                x:Name="TbClassification"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                Margin="4,0,4,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Arial"
                FontSize="11"
                FontWeight="Bold"
                Foreground="{Binding CustomForeColor}"
                LineHeight="13"
                LineStackingStrategy="BlockLineHeight"
                SnapsToDevicePixels="True"
                Text="{Binding Classification}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis" />

            <!-- Keep this only if/when you actually render caveats.
                 For now it is collapsed so classification stays centered. -->
            <TextBlock
                x:Name="TbCaveats"
                Grid.Row="1"
                Grid.Column="1"
                Margin="4,0,4,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                FontFamily="Arial"
                FontSize="9"
                FontWeight="Bold"
                Foreground="{Binding CustomForeColor}"
                LineHeight="11"
                LineStackingStrategy="BlockLineHeight"
                SnapsToDevicePixels="True"
                Text="{Binding CaveatsText}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis" />

            <!-- Right column -->
            <TextBlock
                x:Name="TbMetadata"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="2"
                Margin="4,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontFamily="Arial"
                FontSize="9"
                FontWeight="Normal"
                Foreground="{Binding CustomForeColor}"
                LineHeight="11"
                LineStackingStrategy="BlockLineHeight"
                SnapsToDevicePixels="True"
                Text="{Binding Metadata}"
                TextAlignment="Right"
                TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</borders:BorderBase>