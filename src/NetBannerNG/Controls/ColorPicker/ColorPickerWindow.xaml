<Window
    x:Class="NetBannerNG.Controls.ColorPicker.ColorPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:colorPicker="clr-namespace:NetBannerNG.Controls.ColorPicker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Color Picker"
    Width="574"
    MinWidth="342"
    MinHeight="450"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <DockPanel LastChildFill="False">

        <colorPicker:ColorPickerControl
            x:Name="ColorPicker"
            MinHeight="372"
            Margin="0,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            DockPanel.Dock="Top" />

        <Grid MinHeight="47" DockPanel.Dock="Bottom">
            <Button
                x:Name="CloseButton"
                Width="75"
                Height="27"
                Margin="90,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="CloseButton_Click"
                Content="Close"
                IsCancel="True" />
            <Button
                x:Name="OKButton"
                Width="75"
                Height="27"
                Margin="10,10,0,10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="OKButton_Click"
                Content="OK"
                IsDefault="True" />
            <Button
                x:Name="MinMaxViewButton"
                Width="75"
                Height="27"
                Margin="243,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="MinMaxViewButton_OnClick"
                Content="&lt;&lt; Simple" />
        </Grid>
    </DockPanel>
</Window>