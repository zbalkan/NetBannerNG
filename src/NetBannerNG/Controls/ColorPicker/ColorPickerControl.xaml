<UserControl
    x:Class="NetBannerNG.Controls.ColorPicker.ColorPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:colorPicker="clr-namespace:NetBannerNG.Controls.ColorPicker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinHeight="380"
    d:DesignHeight="380"
    d:DesignWidth="560"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="326" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="286" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <TabControl
                x:Name="TabControl"
                Margin="0,0,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <TabItem Header="Picker 1">
                    <Grid>
                        <Image
                            x:Name="SampleImage"
                            Width="320"
                            Height="240"
                            Margin="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            MouseDown="SampleImage_OnMouseDown"
                            Source="../../Assets/colorpicker1.png" />
                    </Grid>
                </TabItem>
                <TabItem Header="Picker 2">
                    <Grid>
                        <Image
                            x:Name="SampleImage2"
                            Width="254"
                            Height="254"
                            Margin="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            MouseDown="SampleImage2_OnMouseDown"
                            Source="../../Assets/colorpicker2.png" />
                        <Label
                            x:Name="label"
                            Margin="261,2,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Content="Hue" />
                        <Slider
                            x:Name="PickerHueSlider"
                            Height="199"
                            Margin="268,33,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            LargeChange="30"
                            Maximum="360"
                            Minimum="1"
                            Orientation="Vertical"
                            SmallChange="1"
                            ValueChanged="PickerHueSlider_OnValueChanged" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Grid
            Grid.RowSpan="2"
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <Label
                x:Name="rgbLabel"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Content="Red, Green, Blue, Alpha" />
            <colorPicker:SliderRow
                x:Name="RSlider"
                Margin="0,26,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FormatString="F0"
                OnValueChanged="RSlider_OnOnValueChanged" />
            <colorPicker:SliderRow
                x:Name="GSlider"
                Margin="0,54,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FormatString="F0"
                OnValueChanged="GSlider_OnOnValueChanged" />
            <colorPicker:SliderRow
                x:Name="BSlider"
                Margin="0,82,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FormatString="F0"
                OnValueChanged="BSlider_OnOnValueChanged" />
            <colorPicker:SliderRow
                x:Name="ASlider"
                Margin="0,110,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FormatString="F0"
                OnValueChanged="ASlider_OnOnValueChanged" />

            <Label
                x:Name="hsvLabel"
                Margin="0,143,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Content="Hue, Saturation, Value" />
            <colorPicker:SliderRow
                x:Name="HSlider"
                Margin="0,169,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                FormatString="F0"
                OnValueChanged="HSlider_OnOnValueChanged" />
            <colorPicker:SliderRow
                x:Name="SSlider"
                Margin="0,197,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                OnValueChanged="SSlider_OnOnValueChanged" />
            <colorPicker:SliderRow
                x:Name="LSlider"
                Margin="0,225,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                OnValueChanged="LSlider_OnOnValueChanged" />
            <colorPicker:ColorPickerSwatch
                x:Name="CustomColorSwatch"
                Width="230"
                Margin="4,289,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Editable="true"
                OnPickColor="Swatch_OnOnPickColor" />
            <Label
                x:Name="customColorsLabel"
                Margin="0,258,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Content="Custom Colors (Ctrl+Click to set)" />
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Margin="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Border
                    x:Name="ColorDisplayBorder"
                    Width="58"
                    Height="58"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="White"
                    BorderBrush="Black"
                    BorderThickness="2" />

                <colorPicker:ColorPickerSwatch
                    x:Name="Swatch1"
                    Width="260"
                    Height="60"
                    Margin="60,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    OnPickColor="Swatch_OnOnPickColor" />
            </Grid>
            <colorPicker:ColorPickerSwatch
                x:Name="Swatch2"
                Grid.Row="1"
                Margin="0,0,0,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                OnPickColor="Swatch_OnOnPickColor" />
        </Grid>
    </Grid>
</UserControl>